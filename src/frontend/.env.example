# =============================================================================
# API Backend Configuration
# =============================================================================

# URL of the FastAPI backend server
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# Application Insights (optional)
# =============================================================================

# Split into two parts to avoid semicolon-escaping issues in GitHub Actions.
# The app merges these into a full connection string at runtime.
NEXT_PUBLIC_APPINSIGHTS_INSTRUMENTATION_KEY=
# Ingestion endpoint is optional – SDK uses defaults if not specified
NEXT_PUBLIC_APPINSIGHTS_INGESTION_ENDPOINT=

# =============================================================================
# Security
# =============================================================================

# MSAL / Azure AD Configuration
NEXT_PUBLIC_AZURE_AD_CLIENT_ID=your-client-id-here
NEXT_PUBLIC_AZURE_AD_TENANT_ID=your-tenant-id-here
